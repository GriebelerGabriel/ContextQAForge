# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here

# Pipeline Configuration (optional - will use defaults if not set)
CHUNK_SIZE=500
CHUNK_OVERLAP=100
TOP_K=5
NUM_SAMPLES=100
MODEL_NAME=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TEMPERATURE=0.7
MAX_RETRIES=3

# Topic Tree Configuration
TREE_DEGREE=3
TREE_DEPTH=3

# PDF Processing (set to true for LLM-based table/structure extraction - slower but more accurate)
USE_LLM_FOR_PDF=true
PDF_EXTRACTION_MODEL=gpt-4o-mini

# Domain/Subject Focus (e.g., nutrition, technology, medicine, finance)
DOCUMENT_DOMAIN=general

# Language for generated QA pairs (e.g., pt-BR, en, es)
LANGUAGE=pt-BR

# Output Configuration
OUTPUT_PATH=dataset.json
LOG_PATH=pipeline.log