# OpenAI API Configuration
OPENAI_API_KEY=your-api-key-here

# Pipeline Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=100
NUM_SAMPLES=100
MODEL_NAME=gpt-4o
TOPIC_MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_RETRIES=3
BATCH_SIZE=3

# PaddleOCR Configuration
PADDLEOCR_LANG=en
USE_TABLE_RECOGNITION=true

# Tree Refinement
MAX_SECTION_CHARS_FOR_SPLIT=1500

# Domain/Subject Focus (e.g., nutrition, technology, medicine, finance)
DOCUMENT_DOMAIN=general

# Language for generated QA pairs (e.g., pt-BR, en, es)
LANGUAGE=pt-BR

# Output Configuration
OUTPUT_PATH=dataset.json
LOG_PATH=pipeline.log
TREE_PATH=tree/topic_tree.json
PARSED_PATH=tree/parsed
